# Database (use RDS or external Postgres)
# DB_HOST = your RDS endpoint, e.g. mydb.xxxxxx.ap-northeast-1.rds.amazonaws.com
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_HOST=
DB_PORT=5432

OPEN_WEBUI_PORT=3000
WEBUI_DOCKER_TAG=main

# AWS Bedrock (for LiteLLM)
# Option 1 – EC2 with IAM role: leave keys empty; set only AWS_REGION_NAME.
# Option 2 – Local/dev: set access key and secret; IAM user needs bedrock:InvokeModel.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Gemini (for LiteLLM; uses https://generativelanguage.googleapis.com)
# Set in .env or inject at runtime (e.g. AWS Secrets Manager); not exposed in Open WebUI UI.
# Get key at https://aistudio.google.com
GEMINI_API_KEY=

# LiteLLM (Bedrock proxy)
LITELLM_PORT=4000
# API key Open WebUI uses to call LiteLLM (LiteLLM accepts any key by default if no master_key set)
WEBUI_SECRET_KEY=

# Optional: Hugging Face token for higher rate limits and faster HF Hub downloads (https://huggingface.co/settings/tokens)
# HF_TOKEN=